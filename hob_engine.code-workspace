{
    "folders": [
        {
            "path": "scripts"
        }
    ],
    "settings": {
        "files.eol": "\n",
        "files.encoding": "utf8",
        "files.insertFinalNewline": true,
        "files.trimTrailingWhitespace": true,
        "files.associations": {
            "*.lua": "lua"
        },
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "Lua.hint.enable": true,
        "Lua.workspace.checkThirdParty": false,
        "Lua.workspace.library": [
            "meta"
        ],
        "Lua.diagnostics.disable": [
            "lowercase-global",
            "undefined-global",
            "undefined-field",
            "duplicate-set-field",
            "need-check-nil",
            "deprecated",
            "cast-local-type"
        ],
    },
    "extensions": {
        "recommendations": [
            "sumneko.lua",
            "tomblind.local-lua-debugger-vscode"
        ]
    },
    "launch": {
        "version": "0.2.0",
        "configurations": [
            {
                "name": "Debug Lua (hob_engine)",
                "type": "lua-local",
                "request": "launch",
                "linux": {
                    "program": {
                        "command": "${workspaceFolder}/../build/debug/linux-gcc/hob_engine"
                    },
                    "cwd": "${workspaceFolder}/../build/debug/linux-gcc"
                },
                "osx": {
                    "program": {
                        "command": "${workspaceFolder}/../build/debug/macos-clang/hob_engine"
                    },
                    "cwd": "${workspaceFolder}/../build/debug/macos-clang"
                },
                "windows": {
                    "program": {
                        "command": "${workspaceFolder}/../build/debug/windows-msvc/Debug/hob_engine.exe"
                    },
                    "cwd": "${workspaceFolder}/../build/debug/windows-msvc/Debug"
                }
            }
        ]
    }
}
